{
  "name": "desafio-banco-carrefour",
  "version": "1.0.0",
  "description": "Mobile test automation for WebdriverIO native-demo-app - Desafio Banco Carrefour",
  "author": "",
  "license": "MIT",
  "scripts": {
    "test:android": "wdio run wdio.android.conf.js",
    "test:ios": "wdio run wdio.ios.conf.js",
    "test:browserstack": "wdio run wdio.browserstack.conf.js",
    "test:android:login": "wdio run wdio.android.conf.js --spec tests/specs/01_login.spec.js",
    "test:android:signup": "wdio run wdio.android.conf.js --spec tests/specs/02_signup.spec.js",
    "test:android:navigation": "wdio run wdio.android.conf.js --spec tests/specs/03_navigation.spec.js",
    "test:android:form": "wdio run wdio.android.conf.js --spec tests/specs/04_form.spec.js",
    "test:android:e2e": "wdio run wdio.android.conf.js --spec tests/specs/05_e2e.spec.js",
    "test:ios:login": "wdio run wdio.ios.conf.js --spec tests/specs/01_login.spec.js",
    "test:ios:e2e": "wdio run wdio.ios.conf.js --spec tests/specs/05_e2e.spec.js",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "clean": "rm -rf allure-results allure-report errorShots"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^8.32.0",
    "@wdio/appium-service": "^8.32.0",
    "@wdio/browserstack-service": "^8.32.0",
    "@wdio/cli": "^8.32.0",
    "@wdio/local-runner": "^8.32.0",
    "@wdio/mocha-framework": "^8.32.0",
    "@wdio/spec-reporter": "^8.32.0",
    "allure-commandline": "^2.27.0",
    "appium": "^2.5.0",
    "appium-uiautomator2-driver": "^2.45.1",
    "chai": "^4.4.1",
    "ts-node": "^10.9.2"
  }
}
